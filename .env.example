# Polana — Environment Variables
# Copy this to .env.local and fill in the values.
# Never commit .env.local — it is in .gitignore.

# ── Supabase (required) ──────────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# ── Sentry (optional — error monitoring) ─────────────────
EXPO_PUBLIC_SENTRY_DSN=https://KEY@sentry.io/PROJECT_ID

# ── PostHog Analytics (optional) ─────────────────────────
EXPO_PUBLIC_POSTHOG_KEY=phc_YOUR_KEY
# EXPO_PUBLIC_POSTHOG_HOST=https://eu.posthog.com

# ── App Environment ──────────────────────────────────────
# development | staging | production
EXPO_PUBLIC_APP_ENV=development

# ── E2E Testing (CI only) ────────────────────────────────
EXPO_PUBLIC_E2E_SUPABASE_URL=https://YOUR_TEST_PROJECT.supabase.co
EXPO_PUBLIC_E2E_SUPABASE_ANON_KEY=YOUR_TEST_ANON_KEY
EXPO_PUBLIC_E2E_MODE=false
